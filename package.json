{
  "name": "mahod-gis",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Mahod Engineering GIS analysis tool for Israeli transportation data (GTFS / LMS / Roads / Infrastructure)",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "import:gtfs": "node scripts/import-israel-gtfs.mjs",
    "seed:shapes": "tsx scripts/seed/seed-shapes.ts",
    "seed:shapes:rest": "tsx scripts/seed/seed-shapes-rest.ts",
    "seed:accidents-taz": "tsx scripts/seed/seed-accidents-taz-rest.ts",
    "upload:road-authority": "tsx scripts/upload-road-authority-network.ts",
    "seed:stop-route": "node --import \"data:text/javascript,import { register } from 'node:module'; import { pathToFileURL } from 'node:url'; process.env.TS_NODE_PROJECT = 'tsconfig.node.json'; register('ts-node/esm', pathToFileURL('./'));\" scripts/seed/seed-stop-route.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,md,json}\"",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@geoman-io/leaflet-geoman-free": "^2.19.3",
    "@radix-ui/react-slot": "^1.1.0",
    "@supabase/supabase-js": "^2.45.4",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-table": "^8.21.3",
    "@turf/area": "^7.2.0",
    "@types/geojson": "^7946.0.16",
    "@types/mapbox-gl": "^3.4.1",
    "@types/proj4": "^2.5.6",
    "class-variance-authority": "^0.7.0",
    "cli-progress": "^3.12.0",
    "clsx": "^2.1.1",
    "csv-parser": "^3.2.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.451.0",
    "mapbox-gl": "^3.23.1",
    "proj4": "^2.20.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.26.2",
    "recharts": "^3.8.1",
    "shpjs": "^6.2.0",
    "tailwind-merge": "^2.5.2",
    "ws": "^8.20.1",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.11.1",
    "@tanstack/react-query-devtools": "^5.59.0",
    "@types/cli-progress": "^3.11.6",
    "@types/jsdom": "^28.0.3",
    "@types/leaflet": "^1.9.12",
    "@types/node": "^22.7.4",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/unzipper": "^0.10.11",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.2",
    "@vitest/coverage-v8": "^4.1.6",
    "autoprefixer": "^10.4.20",
    "csv-parse": "^5.6.0",
    "csv-stringify": "^6.5.2",
    "eslint": "^9.11.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "globals": "^15.10.0",
    "jsdom": "^27.0.1",
    "node-stream-zip": "^1.15.0",
    "pg": "^8.13.1",
    "pg-copy-streams": "^6.0.6",
    "pg-mem": "^3.0.14",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "tailwindcss": "^3.4.13",
    "tailwindcss-rtl": "^0.9.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.0",
    "unzipper": "^0.12.3",
    "vite": "^5.4.8",
    "vitest": "^4.1.6"
  }
}
