# --- Supabase ---
# Copy this file to `.env.local` and fill in values once a Supabase project is provisioned.
# Base URL only: https://<project-ref>.supabase.co (do not append /rest/v1).
# SQL schema: supabase/migrations/20260513120000_initial_schema.sql
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Direct Postgres (for scripts: seed shapes / stop-route / upload:road-authority). Dashboard → Database → URI, sslmode=require.
# Alternatively set only SUPABASE_DB_PASS (Database password) if VITE_SUPABASE_URL is already set — host db.<ref>.supabase.co is inferred.
DATABASE_URL=
# SUPABASE_DB_PASS=

# Optional: path to extracted stop_times.txt for npm run seed:stop-route (defaults to public/gtfs or data/gtfs).
# STOP_TIMES_PATH=

# Optional: stored in gtfs_stop_route.source_version (defaults to today's date YYYY-MM-DD).
# GTFS_VERSION=

# Optional: absolute URL for the Node export API (GeoJSON/HTML/PDF). Leave empty in dev to use Vite proxy to localhost:3333.
# VITE_EXPORT_API_URL=
VITE_APP_NAME="Mahod GIS"
VITE_APP_VERSION="2.4.1"
